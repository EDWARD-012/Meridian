SECRET_KEY=change-me-to-a-long-random-string-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ─── Database mode ───────────────────────────────────────────
# True  = SQLite file (backend/db.sqlite3) — no username/password
# False = MySQL — set DATABASE_URL or DB_* variables below
USE_SQLITE=True

# ─── MySQL (when USE_SQLITE=False) ─────────────────────────
# Option A: single URL (cloud / Render)
# DATABASE_URL=mysql://user:password@host:3306/ecommerce_db

# Option B: separate fields (local XAMPP)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=ecommerce_db
# DB_USER=meridian_user
# DB_PASSWORD=yourpassword
# DB_HOST=127.0.0.1
# DB_PORT=3306

# ─── Production (Render) ─────────────────────────────────────
# DEBUG=False
# USE_SQLITE=False
# ALLOWED_HOSTS=your-app.onrender.com,.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# SECURE_SSL_REDIRECT=True
# DATABASE_URL=mysql://user:pass@host:3306/ecommerce_db

# Docs: ../docs/MYSQL_SETUP.md | ../docs/DEPLOYMENT.md
